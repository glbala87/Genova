# =============================================================================
# Genova API Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

# --- Authentication (enabled by default) ---
# Set to 0 to disable for local development ONLY.
GENOVA_AUTH_ENABLED=1

# Comma-separated API keys. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
GENOVA_API_KEYS=REPLACE_ME_WITH_A_REAL_KEY

# Or load keys from a file (one per line):
# GENOVA_API_KEYS_FILE=/etc/genova/api_keys.txt

# Optional: JWT authentication
# GENOVA_JWT_SECRET=your-jwt-secret-here
# GENOVA_JWT_ALGORITHM=HS256

# --- Rate Limiting (enabled by default) ---
GENOVA_RATE_LIMIT_ENABLED=1
GENOVA_RATE_LIMIT_RPM=60
GENOVA_RATE_LIMIT_BACKEND=memory
# For multi-instance deployments, use Redis:
# GENOVA_RATE_LIMIT_BACKEND=redis
# GENOVA_REDIS_URL=redis://localhost:6379/0

# --- CORS ---
# Comma-separated list of allowed origins. Leave empty to allow all (dev only).
GENOVA_CORS_ORIGINS=https://your-domain.com

# --- Observability (all off by default) ---
GENOVA_METRICS_ENABLED=0
GENOVA_TRACING_ENABLED=0
GENOVA_REQUEST_LOGGING_ENABLED=0

# --- Model ---
# GENOVA_MODEL_PATH=/models/genova/best_model.pt
# GENOVA_DEVICE=auto
